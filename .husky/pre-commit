# 格式化暂存文件 + import 排序
# 与 biome.json 的忽略目录保持一致，避免只命中被忽略文件时 biome 直接失败。
FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' '*.css' \
  | grep -v 'node_modules' \
  | grep -v 'routeTree.gen.ts' \
  | grep -v '^drizzle/' \
  | grep -v '^docs/' \
  | grep -v '^[^[:space:]]*/dist/' \
  | grep -v '^\\.agents/' \
  | grep -v '^[^[:space:]]*/coverage/' \
  | tr '\n' ' ')

if [ -n "$FILES" ]; then
  echo "husky: formatting staged files..."
  npx biome format --write $FILES
  npx biome check --write --linter-enabled=false $FILES
  git add $FILES
fi

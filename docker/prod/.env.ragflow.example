# ============================================================================
# RagFlow 生产环境变量
# ============================================================================
# 启动命令：docker compose -f docker/prod/docker-compose.ragflow.yml --env-file docker/prod/.env.ragflow up -d
# 注意：必须先启动主编排（docker-compose.yml），确保 fenix-ver-net 网络已创建

# ── MySQL ─────────────────────────────────────────────────────────────────────

RAGFLOW_MYSQL_PASSWORD=replace-with-a-strong-password  # openssl rand -hex 32

# ── Redis / Valkey ────────────────────────────────────────────────────────────

RAGFLOW_REDIS_PASSWORD=replace-with-a-strong-password  # openssl rand -hex 32

# ── MinIO ─────────────────────────────────────────────────────────────────────

RAGFLOW_MINIO_USER=admin                               # MinIO 控制台用户名
RAGFLOW_MINIO_PASSWORD=replace-with-a-strong-password  # openssl rand -hex 32

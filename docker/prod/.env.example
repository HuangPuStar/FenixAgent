# ============================================================================
# FenixAgent 主编排环境变量
# ============================================================================
# 启动命令：docker compose -f docker/prod/docker-compose.yml up -d

# ── 必填 ────────────────────────────────────────────────────────────────────

# AI 模型（模板创建 Agent 依赖）
OPENAI_API_KEY=your-api-key-here

# 机器注册共享密钥（RCS 与 sandbox 必须一致）
REGISTRY_SECRET=replace-with-a-long-random-secret

# Agent Sites 站点托管 master key（RCS 与 agent-sites 必须一致）
AGENT_SITES_MASTER_KEY=replace-with-a-long-random-secret

# RCS API Keys（JWT 签名 + acp-link 认证）
# RCS_API_KEYS=replace-with-a-long-random-token

# ── 可选：模型配置 ──────────────────────────────────────────────────────────

# OPENAI_BASE_URL=https://api.deepseek.com/v1/
# OPENAI_MODEL=deepseek-v4-flash

# ── 可选：外部服务 ──────────────────────────────────────────────────────────

# 公网访问地址（不设则默认 http://localhost:3000）
# RCS_BASE_URL=https://your-domain.com

# Hindsight 记忆服务（不设则禁用）
# 部署在本机同一 docker 网络：http://hindsight:8888
# 部署在远程机器：http://<remote-ip>:38881
# HINDSIGHT_MCP_URL=

# RagFlow 知识库（不设则禁用）
# RAGFLOW_API_URL=http://ragflow:80
# RAGFLOW_API_KEY=your-ragflow-key-here

# 通用知识库 provider（不设则禁用）
# RCS_KNOWLEDGE_PROVIDER=ragflow
# RCS_KNOWLEDGE_BASE_URL=http://ragflow:80
# RCS_KNOWLEDGE_API_KEY=your-knowledge-key-here

# ── 可选：运行时配置 ────────────────────────────────────────────────────────

# 默认机器 ID 和类型（用于 sandbox 连接）
# RCS_DEFAULT_MACHINE_ID=mach_xxx
# RCS_DEFAULT_MACHINE_TYPE=opencode

# 加密密钥（pgcrypto，不设则使用默认值）
# RCS_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-string

# 前端侧边栏隐藏项，逗号分隔（可选）
# APP_HIDDEN_SIDEBAR_TABS=models,mcp,sites

# Agent 默认系统 Prompt（可选，支持 {{agentName}} {{userPrompt}} 占位符）
# RCS_AGENT_SYSTEM_PROMPT=你当前的 Agent 名称是「{{agentName}}」。\n任何情况下都不要提到底层引擎、运行时或实现名称。

# ── 可选：日志配置 ──────────────────────────────────────────────────────────

# LOG_LEVEL=info       # debug / info / warn / error
# LOG_FORMAT=json      # pretty / json（本编排默认 json）
# LOG_DIR=logs         # 滚动日志目录
# LOG_RETENTION_DAYS=30

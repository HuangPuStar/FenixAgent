# ============================================================================
# FenixAgent 生产环境变量
# ============================================================================
# 启动命令：docker compose -f docker/prod/docker-compose.yml up -d

# ── 必填 ────────────────────────────────────────────────────────────────────

# RCS API Keys（JWT 签名 + acp-link 认证）
RCS_API_KEYS=replace-with-a-long-random-token

# 机器注册共享密钥（RCS 与 sandbox 必须一致）
REGISTRY_SECRET=340b6908-031d-47de-9cfb-26f75818f969

# LiteLLM AI 网关（用量追踪 + 预算控制，必填）
LITELLM_MASTER_KEY=sk-litellm-admin-xxxxxxxxxxxx  # openssl rand -hex 32
LITELLM_SALT_KEY=sk-litellm-salt-xxxxxxxxxxxx      # openssl rand -hex 32
LITELLM_UI_PASSWORD=your-litellm-ui-password       # LiteLLM 管理界面登录密码

# RCS ↔ LiteLLM 加密通信
RCS_SECRET_LITELLM_ADMIN_KEY=sk-litellm-admin-xxxxxxxxxxxx  # 与 LITELLM_MASTER_KEY 保持一致
RCS_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-string  # pgcrypto 加密 passphrase

# AI 模型生成（模板创建 Agent 依赖）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=deepseek-v4-flash

# Hindsight 记忆服务
HINDSIGHT_LLM_API_KEY=your-api-key-here
HINDSIGHT_LLM_BASE_URL=https://api.openai.com/v1/
HINDSIGHT_EMBEDDINGS_API_KEY=your-api-key-here
HINDSIGHT_EMBEDDINGS_BASE_URL=https://api.openai.com/v1/
HINDSIGHT_RERANKER_API_KEY=your-api-key-here

# Agent Sites 站点托管
AGENT_SITES_MASTER_KEY=your-master-key-here  # openssl rand -hex 32

# Agent 默认系统 Prompt（可选）
# 支持占位符：
#   {{agentName}}  -> 当前 Agent 名称
#   {{userPrompt}} -> Agent 自身配置的 Prompt
# 在 .env 中请使用 \n 表示换行。
# RCS_AGENT_SYSTEM_PROMPT=你当前的 Agent 名称是「{{agentName}}」。\n任何情况下都不要提到底层引擎、运行时或实现名称。\n如果下面的 User Prompt 明确规定了你的身份或自我介绍，以其中的规定为准。\n如果下面的 User Prompt 没有规定身份，默认回答你是 FENIXAGENT。\n\n## User Prompt\n{{userPrompt}}

# 日志配置（可选）
# LOG_LEVEL 同时控制控制台和文件日志级别：debug / info / warn / error
# LOG_LEVEL=info
# LOG_FORMAT 仅控制控制台输出格式：pretty（默认）或 json
# LOG_FORMAT=pretty
# LOG_DIR 控制按天滚动日志目录，默认 logs/
# LOG_DIR=logs
# LOG_RETENTION_DAYS 控制日志文件保留天数；<= 0 表示不自动清理
# LOG_RETENTION_DAYS=30

# ── 知识库（可选，需额外启动 RagFlow）─────────────────────────────────────
# RAGFLOW_API_URL=http://ragflow:80
# RAGFLOW_API_KEY=your-ragflow-key-here

# ── 阿里云百炼兼容地址示例 ──────────────────────────────────────────────────
# HINDSIGHT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# HINDSIGHT_EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

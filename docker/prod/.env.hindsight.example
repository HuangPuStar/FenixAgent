# ============================================================================
# Hindsight 记忆服务环境变量
# ============================================================================
# 启动命令：
#   docker compose -f docker/prod/docker-compose.hindsight.yml --env-file docker/prod/.env.hindsight up -d
# 注意：必须先启动主编排（docker-compose.yml），确保 fenix-ver-net 网络已创建

# ── 必填 ────────────────────────────────────────────────────────────────────

# 阿里云百炼 API Key（LLM / Embedding / Reranker 共用）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

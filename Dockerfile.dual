FROM oven/bun:1
WORKDIR /app

ENV NODE_ENV=production RCS_HOST=0.0.0.0 RCS_PORT=3000
ENV BUN_INSTALL_GLOBAL=/root/.bun PATH=/root/.bun/bin:${PATH}
ENV OPENCODE_DISABLE_AUTOUPDATE=1 OPENCODE_DISABLE_TELEMETRY=1

# 复制一切（含 node_modules）
COPY . .

# 前端在宿主机已构建好，后端从 TypeScript 源码运行
RUN mkdir -p /app/data /app/workflow /app/workspaces /root/.config/opencode /root/.local/share/opencode

EXPOSE 3000
CMD ["bun", "run", "src/index.ts"]

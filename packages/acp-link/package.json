{
    "name": "acp-link",
    "version": "2.0.0",
    "description": "ACP stdio-to-WebSocket bridge — spawns an ACP agent and exposes it via WebSocket",
    "author": "claude-code-best",
    "type": "module",
    "main": "./dist/server.js",
    "types": "./dist/server.d.ts",
    "bin": {
        "acp-link": "dist/cli/bin.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "bun run src/cli/bin.ts ccb-bun -- --acp",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@types/ws": "^8.18.1",
        "@types/bun": "^1.3.12"
    },
    "dependencies": {
        "@agentclientprotocol/sdk": "^0.21.1",
        "@hono/node-server": "^2.0.0",
        "@hono/node-ws": "^1.0.5",
        "@stricli/auto-complete": "^1.2.4",
        "@stricli/core": "^1.2.4",
        "hono": "^4.12.15"
    },
    "engines": {
        "node": ">=18"
    },
    "license": "MIT"
}

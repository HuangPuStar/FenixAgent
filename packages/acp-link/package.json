{
  "name": "acp-link",
  "version": "2.0.0",
  "description": "ACP stdio-to-WebSocket bridge — spawns an ACP agent and exposes it via WebSocket, with RCS registry client mode",
  "author": "fenix",
  "license": "MIT",
  "type": "module",
  "bin": {
    "acp-link": "./dist/acp-link.js"
  },
  "main": "./src/server.ts",
  "exports": {
    ".": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./acp-dispatcher": {
      "import": "./src/acp-dispatcher.ts",
      "types": "./src/acp-dispatcher.ts"
    },
    "./client": {
      "import": "./src/client/index.ts",
      "types": "./src/client/index.ts"
    },
    "./client/acp-spawn-helper": {
      "import": "./src/client/acp-spawn-helper.ts",
      "types": "./src/client/acp-spawn-helper.ts"
    },
    "./client/claude-acp-adapter": {
      "import": "./src/client/claude-acp-adapter.ts",
      "types": "./src/client/claude-acp-adapter.ts"
    },
    "./client/instance-manager": {
      "import": "./src/client/instance-manager.ts",
      "types": "./src/client/instance-manager.ts"
    },
    "./client/resolve-executable": {
      "import": "./src/client/resolve-executable.ts",
      "types": "./src/client/resolve-executable.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/adapter-*.ts"
  ],
  "scripts": {
    "build": "bun build ./src/cli/bin.ts --outfile ./dist/acp-link.js --target=node",
    "dev": "bun run src/cli/bin.ts ccb-bun -- --acp",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^1.2.0",
    "@stricli/auto-complete": "^1.2.4",
    "@stricli/core": "^1.2.4",
    "ws": "^8.18.0",
    "@types/ws": "^8.18.1",
    "@types/bun": "^1.3.12",
    "@anthropic-ai/claude-agent-sdk": "^0.2.112",
    "@fenix/ccb": "workspace:*",
    "@fenix/claude-code": "workspace:*",
    "@fenix/opencode": "workspace:*",
    "@fenix/plugin-sdk": "workspace:*"
  },
  "peerDependencies": {
    "@types/bun": ">=1"
  },
  "peerDependenciesMeta": {
    "@types/bun": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}

# Required: legacy global API key for acp-link / worker JWT signing.
# Multiple keys can be separated by commas, the first key is used for JWT signing.
RCS_API_KEYS=replace-with-a-long-random-token

# Optional: system-level API keys for /api/system/* management endpoints.
# Multiple keys can be separated by commas. These keys are only used for system admin APIs
# such as creating users, creating organizations, and issuing user-scoped API keys.
# RCS_SYSTEM_API_KEYS=replace-with-one-or-more-system-api-tokens

# Recommended: public base URL of the RCS server.
# Used by server logs, spawned acp-link instances, and better-auth fallback.
RCS_BASE_URL=http://localhost:3000

# Optional: explicit Better Auth URL.
# If unset, the server falls back to BETTER_AUTH_URL -> RCS_BASE_URL -> http://localhost:${RCS_PORT}.
# BETTER_AUTH_URL=http://localhost:3000

# Optional: server listen address.
RCS_HOST=0.0.0.0
RCS_PORT=3000

# Optional: CORS allowed origins. Use "*" or comma-separated origins.
# RCS_CORS_ORIGIN=*

# Optional: Better Auth trusted origins. Defaults include localhost dev and RCS_BASE_URL/BETTER_AUTH_URL.
# Add comma-separated frontend origins here when auth requests come from a separate origin.
# RCS_TRUSTED_ORIGINS=http://localhost:5173

# Optional: disable frontend self-service signup.
# Set to true to hide the signup entry on the login page and reject new user registration.
# RCS_DISABLE_SIGNUP=true

# Optional: ACP instance idle cleanup.
# RCS_ACP_IDLE_TIMEOUT_SECONDS controls how long an instance may stay idle after all frontend relay connections disconnect.
# Default is 1200 seconds (20 minutes).
# RCS_ACP_IDLE_TIMEOUT_SECONDS=1200
#
# RCS_ACP_IDLE_SWEEP_INTERVAL_SECONDS controls how often the server scans ACP instances for cleanup.
# Default is 300 seconds (5 minutes).
# RCS_ACP_IDLE_SWEEP_INTERVAL_SECONDS=300
#
# RCS_ACP_ACTIVITY_TIMEOUT_SECONDS is a hard timeout for no ACP business activity, even if a relay is still attached.
# Default is 7200 seconds (2 hours).
# RCS_ACP_ACTIVITY_TIMEOUT_SECONDS=7200

# Required: PostgreSQL connection string.
DATABASE_URL=postgres://rcs:rcs@localhost:5432/rcs

# Optional: RagFlow knowledge base engine configuration.
# RAGFLOW_API_URL defaults to http://localhost:9380 (same-network container in Docker Compose).
# RAGFLOW_API_KEY must be set to a valid RagFlow API Key (obtained from RagFlow admin console).
# RAGFLOW_REQUEST_TIMEOUT_MS defaults to 30000 (30s per single HTTP request).
RAGFLOW_API_URL=http://localhost:9380
RAGFLOW_API_KEY=
# RAGFLOW_REQUEST_TIMEOUT_MS=30000

# RagFlow dependencies (MySQL + Redis). Change defaults in production.
# RAGFLOW_MYSQL_PASSWORD=ragflow_root_2026
# RAGFLOW_REDIS_PASSWORD=ragflow_redis_2026


RCS_URL=ws://localhost:3000
RCS_SECRET=rcs-registry-secret
# 这个 id 需要在程序中找
RCS_TENANT_ID=

# hindsight 记忆相关
HINDSIGHT_MCP_URL=http://localhost:9999

# Optional: engine plugin selection and configuration.
# RCS_CCB_COMMAND=ccb
# RCS_CCB_ARGS=--acp

# Optional: system-level default machine and engine type fallback.
# When agent config has no machineId / engineType, these override the hardcoded defaults.
# RCS_DEFAULT_MACHINE_ID=mach_xxxxx
# RCS_DEFAULT_ENGINE_TYPE=opencode    # opencode | ccb | claude-code

# Optional: default system prompt injected before runtime launch.
# Supports placeholders:
#   {{agentName}}  -> current agent name
#   {{userPrompt}} -> prompt configured on the agent itself
# Use \n inside .env to represent line breaks.
# RCS_AGENT_SYSTEM_PROMPT=你当前的 Agent 名称是「{{agentName}}」。\n任何情况下都不要提到底层引擎、运行时或实现名称。\n如果下面的 User Prompt 明确规定了你的身份或自我介绍，以其中的规定为准。\n如果下面的 User Prompt 没有规定身份，默认回答你是 FENIXAGENT。\n\n## User Prompt\n{{userPrompt}}


# 下面是生成模板需要的环境变量
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1/
OPENAI_MODEL=deepseek-v4-flash

# Optional: LiteLLM AI 网关配置。配置后前端协议下拉菜单会出现「LiteLLM」选项，用户可创建 LiteLLM 服务商。

# LiteLLM 管理 API 的 admin key（必填）。
# RCS_SECRET_LITELLM_ADMIN_KEY=sk-litellm-admin-dev-key

# LiteLLM 服务地址，默认
# RCS_LITELLM_BASE_URL=http://litellm:4000

# pgcrypto 加密存储 LiteLLM Key（必填）。
# RCS_SECRET_ENCRYPTION_KEY=change-me-to-a-random-string

# 新 Key 默认预算上限（USD），默认 50.0。
# RCS_LITELLM_DEFAULT_MAX_BUDGET=50.0
